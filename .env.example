# ===========================================================================
# .env.example — Copy this to .env and fill in your values.
# .env is gitignored and never committed.
# ===========================================================================
#
# Usage:
#   cp .env.example .env
#   # edit .env with your real values
#
# ===========================================================================

# Your OSC project/allocation ID (shown in `squeue` output, e.g. PAS1234)
OSC_ACCOUNT=PAS0000

# Your OSC-registered email address (used for SLURM job notifications)
OSC_EMAIL=your@email.osu.edu

# Name of your conda environment on OSC
CONDA_ENV=log_anomaly

# Absolute path to your project root on OSC
# Tip: run `pwd` from your project directory to get this
PROJECT_DIR=$HOME/LSTM

# OSC module versions — check available versions with `module spider cuda`
MODULE_CONDA=miniconda3/24.1.2-py310
MODULE_CUDA=cuda/11.8.0