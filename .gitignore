# ===========================================================================
# .gitignore — LSTM Autoencoder Log Anomaly Detector
# ===========================================================================

# ---------------------------------------------------------------------------
# Credentials — NEVER commit
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# Data — large files, live on OSC scratch storage
# ---------------------------------------------------------------------------
data/
*.npy
*.csv
*.log

# ---------------------------------------------------------------------------
# Model outputs — generated, not source
# ---------------------------------------------------------------------------
checkpoints/
runs/
plots/
smoke_out/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
env/
.venv/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# OS / editor clutter
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ---------------------------------------------------------------------------
# SLURM job output (generated at runtime)
# ---------------------------------------------------------------------------
logs/
slurm-*.out